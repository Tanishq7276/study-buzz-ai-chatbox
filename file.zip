<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Study Buddy AI — Code Sangram 2026</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap');

  :root{
    --p:#534AB7;--p2:#3C3489;--p3:#26215C;
    --acc:#D4537E;--acc2:#993556;
    --teal:#1D9E75;--teal2:#0F6E56;
    --txt:#CECBF6;--txt2:rgba(175,169,236,0.65);--txt3:rgba(175,169,236,0.35);
    --bg:#0a0818;--bg2:rgba(83,74,183,0.07);--bg3:rgba(255,255,255,0.03);
    --border:rgba(167,139,250,0.15);--border2:rgba(83,74,183,0.35);
  }

  *{box-sizing:border-box;margin:0;padding:0;-webkit-font-smoothing:antialiased}
  html,body{height:100%;overflow:hidden}

  body{
    font-family:'Space Grotesk',system-ui,sans-serif;
    background:var(--bg);
    display:flex;align-items:center;justify-content:center;
    min-height:100vh;
    background-image:
      radial-gradient(ellipse at 15% 20%, rgba(83,74,183,0.18) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 80%, rgba(153,53,86,0.14) 0%, transparent 55%),
      radial-gradient(ellipse at 50% 100%, rgba(29,158,117,0.08) 0%, transparent 50%);
  }

  /* Animated bg particles */
  .particle{position:fixed;border-radius:50%;pointer-events:none;z-index:0;opacity:0.06}
  .p1{width:400px;height:400px;top:-100px;left:-100px;background:#534AB7;animation:pa 12s ease-in-out infinite}
  .p2{width:300px;height:300px;bottom:-80px;right:-80px;background:#993556;animation:pb 15s ease-in-out infinite}
  .p3{width:200px;height:200px;top:40%;left:60%;background:#1D9E75;animation:pc 10s ease-in-out infinite}
  @keyframes pa{0%,100%{transform:scale(1) translate(0,0)}50%{transform:scale(1.4) translate(40px,30px)}}
  @keyframes pb{0%,100%{transform:scale(1) translate(0,0)}50%{transform:scale(1.3) translate(-35px,-25px)}}
  @keyframes pc{0%,100%{transform:scale(1) translate(0,0)}50%{transform:scale(1.5) translate(-30px,20px)}}

  /* Floating sparkles */
  .spark{position:fixed;pointer-events:none;z-index:0;color:rgba(167,139,250,0.4);font-size:14px;animation:sparkF linear infinite}
  @keyframes sparkF{0%{opacity:0;transform:translateY(0) rotate(0deg)}10%{opacity:1}90%{opacity:0.5}100%{opacity:0;transform:translateY(-120px) rotate(360deg)}}

  /* Main card */
  .app{
    width:100%;max-width:820px;height:96vh;max-height:820px;
    background:#0d0b1e;
    border:1px solid var(--border2);
    border-radius:28px;
    overflow:hidden;display:flex;flex-direction:column;
    position:relative;z-index:1;
    box-shadow:0 0 80px rgba(83,74,183,0.15),0 0 160px rgba(83,74,183,0.06),inset 0 1px 0 rgba(255,255,255,0.06);
  }

  /* Header */
  .header{
    padding:18px 24px;
    border-bottom:1px solid var(--border);
    display:flex;align-items:center;gap:16px;
    background:linear-gradient(135deg,rgba(83,74,183,0.1),rgba(38,33,92,0.05));
    flex-shrink:0;
  }
  .logo{
    width:50px;height:50px;border-radius:16px;
    background:linear-gradient(135deg,#534AB7,#993556);
    display:flex;align-items:center;justify-content:center;
    font-size:22px;flex-shrink:0;
    box-shadow:0 8px 24px rgba(83,74,183,0.4);
    animation:logoF 3.5s ease-in-out infinite;
  }
  @keyframes logoF{0%,100%{transform:rotate(-4deg) translateY(0)}50%{transform:rotate(4deg) translateY(-5px)}}
  .header-text{flex:1}
  .header-text h1{
    font-size:18px;font-weight:700;
    background:linear-gradient(135deg,#AFA9EC,#ED93B1,#5DCAA5);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    letter-spacing:-0.5px;
  }
  .header-text p{font-size:12px;color:var(--txt3);margin-top:3px}
  .status-badge{
    display:flex;align-items:center;gap:7px;
    background:rgba(93,202,165,0.08);
    border:1px solid rgba(93,202,165,0.2);
    border-radius:999px;padding:5px 14px;
    font-size:12px;color:#9FE1CB;font-weight:500;
  }
  .sdot{width:8px;height:8px;border-radius:50%;background:#5DCAA5;animation:sdp 2s infinite}
  @keyframes sdp{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(93,202,165,0.4)}50%{opacity:0.5;box-shadow:0 0 0 4px rgba(93,202,165,0)}}

  /* API Key band */
  .api-band{
    padding:10px 24px;
    border-bottom:1px solid var(--border);
    display:flex;align-items:center;gap:12px;flex-wrap:wrap;
    background:rgba(212,83,126,0.04);
    flex-shrink:0;
  }
  .api-band label{font-size:12px;color:rgba(237,147,177,0.8);font-weight:600;white-space:nowrap}
  .api-band input{
    flex:1;min-width:200px;
    padding:7px 12px;
    border:1px solid rgba(212,83,126,0.3);
    border-radius:10px;font-size:12px;
    background:rgba(255,255,255,0.03);color:#CECBF6;
    font-family:'DM Mono',monospace;
  }
  .api-band input:focus{outline:none;border-color:rgba(212,83,126,0.6)}
  .api-band input::placeholder{color:rgba(175,169,236,0.3)}
  .connect-btn{
    padding:7px 18px;
    background:linear-gradient(135deg,#D4537E,#993556);
    color:#fff;border:none;border-radius:10px;
    font-size:12px;font-weight:600;cursor:pointer;
    font-family:'Space Grotesk',sans-serif;
    transition:all 0.2s;white-space:nowrap;
  }
  .connect-btn:hover{transform:scale(1.04);box-shadow:0 4px 16px rgba(212,83,126,0.35)}
  .api-note{font-size:11px;color:rgba(175,169,236,0.3);width:100%}

  /* Subjects */
  .subjects{
    display:flex;gap:8px;padding:11px 24px;
    overflow-x:auto;border-bottom:1px solid var(--border);
    flex-shrink:0;scrollbar-width:none;
  }
  .subjects::-webkit-scrollbar{display:none}
  .subpill{
    padding:6px 15px;border-radius:999px;
    font-size:12px;font-weight:600;cursor:pointer;
    border:1px solid var(--border);
    background:rgba(255,255,255,0.03);
    color:var(--txt3);white-space:nowrap;
    font-family:'Space Grotesk',sans-serif;
    transition:all 0.2s;
  }
  .subpill.on{
    background:linear-gradient(135deg,#534AB7,#3C3489);
    color:#EEEDFE;border-color:transparent;
    box-shadow:0 4px 16px rgba(83,74,183,0.35);
    transform:translateY(-1px);
  }
  .subpill:hover:not(.on){background:rgba(83,74,183,0.12);color:#AFA9EC;border-color:rgba(83,74,183,0.35);transform:translateY(-1px)}

  /* Messages */
  .messages{
    flex:1;overflow-y:auto;padding:20px 24px;
    display:flex;flex-direction:column;gap:18px;
    scrollbar-width:thin;scrollbar-color:rgba(83,74,183,0.3) transparent;
  }
  .messages::-webkit-scrollbar{width:4px}
  .messages::-webkit-scrollbar-track{background:transparent}
  .messages::-webkit-scrollbar-thumb{background:rgba(83,74,183,0.3);border-radius:4px}

  /* Welcome */
  .welcome{text-align:center;padding:28px 16px;animation:fadeUp 0.6s cubic-bezier(0.34,1.56,0.64,1)}
  @keyframes fadeUp{from{opacity:0;transform:translateY(20px) scale(0.96)}to{opacity:1;transform:translateY(0) scale(1)}}
  .welcome-icon{
    width:72px;height:72px;border-radius:24px;
    background:linear-gradient(135deg,#3C3489,#26215C);
    border:1px solid rgba(83,74,183,0.4);
    display:flex;align-items:center;justify-content:center;
    margin:0 auto 18px;font-size:30px;
    box-shadow:0 12px 32px rgba(83,74,183,0.3);
    animation:icoF 3s ease-in-out infinite;
  }
  @keyframes icoF{0%,100%{transform:rotate(-6deg) scale(1) translateY(0)}50%{transform:rotate(6deg) scale(1.1) translateY(-4px)}}
  .welcome h2{
    font-size:20px;font-weight:700;
    background:linear-gradient(135deg,#CECBF6,#F4C0D1,#9FE1CB);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    margin-bottom:10px;
  }
  .welcome p{font-size:13px;color:var(--txt2);line-height:1.8;max-width:340px;margin:0 auto}
  .chips{display:flex;flex-wrap:wrap;gap:9px;margin-top:22px;justify-content:center}
  .chip{
    padding:8px 14px;
    background:rgba(83,74,183,0.1);
    border:1px solid rgba(83,74,183,0.25);
    border-radius:12px;font-size:12px;
    cursor:pointer;color:rgba(175,169,236,0.8);
    text-align:left;
    font-family:'Space Grotesk',sans-serif;
    transition:all 0.2s;line-height:1.4;
  }
  .chip:hover{background:rgba(83,74,183,0.22);border-color:rgba(83,74,183,0.55);color:#CECBF6;transform:translateY(-2px);box-shadow:0 4px 14px rgba(83,74,183,0.2)}

  /* Bubbles */
  .msg{display:flex;flex-direction:column;max-width:82%;animation:msgIn 0.35s cubic-bezier(0.34,1.56,0.64,1)}
  @keyframes msgIn{from{opacity:0;transform:translateY(12px) scale(0.94)}to{opacity:1;transform:translateY(0) scale(1)}}
  .msg.user{align-self:flex-end;align-items:flex-end}
  .msg.bot{align-self:flex-start;align-items:flex-start}
  .bot-label{font-size:10px;color:#7F77DD;margin-bottom:5px;font-weight:700;letter-spacing:1px}
  .bubble{padding:12px 16px;border-radius:20px;font-size:13.5px;line-height:1.75;white-space:pre-wrap;word-break:break-word;font-family:'Space Grotesk',sans-serif}
  .msg.user .bubble{
    background:linear-gradient(135deg,#534AB7,#3C3489);
    color:#EEEDFE;border-bottom-right-radius:5px;
    box-shadow:0 6px 20px rgba(83,74,183,0.35);
  }
  .msg.bot .bubble{
    background:rgba(255,255,255,0.04);
    color:rgba(175,169,236,0.9);
    border-bottom-left-radius:5px;
    border:1px solid rgba(167,139,250,0.13);
    box-shadow:0 4px 16px rgba(0,0,0,0.15);
  }

  /* Typing */
  .typing-dots{display:flex;gap:5px;align-items:center;padding:14px 18px}
  .td{width:8px;height:8px;border-radius:50%;background:#7F77DD;animation:td 1.2s infinite}
  .td:nth-child(2){animation-delay:0.2s}.td:nth-child(3){animation-delay:0.4s}
  @keyframes td{0%,60%,100%{transform:translateY(0);opacity:0.7}30%{transform:translateY(-9px);opacity:1}}

  /* Input */
  .input-area{
    padding:14px 24px;
    border-top:1px solid var(--border);
    display:flex;gap:10px;align-items:flex-end;
    background:rgba(0,0,0,0.2);flex-shrink:0;
  }
  .input-area textarea{
    flex:1;border:1px solid var(--border2);border-radius:16px;
    padding:11px 16px;font-size:13px;
    font-family:'Space Grotesk',sans-serif;
    resize:none;background:rgba(255,255,255,0.03);
    color:#CECBF6;max-height:120px;line-height:1.55;min-height:44px;
    transition:border-color 0.2s,box-shadow 0.2s;
  }
  .input-area textarea::placeholder{color:var(--txt3)}
  .input-area textarea:focus{outline:none;border-color:#534AB7;box-shadow:0 0 0 4px rgba(83,74,183,0.12)}
  .send-btn{
    width:44px;height:44px;border-radius:14px;
    background:linear-gradient(135deg,#534AB7,#3C3489);
    border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;
    flex-shrink:0;transition:all 0.2s;
    box-shadow:0 6px 20px rgba(83,74,183,0.4);color:#fff;
  }
  .send-btn:hover{transform:scale(1.1) translateY(-2px);box-shadow:0 8px 28px rgba(83,74,183,0.55)}
  .send-btn:active{transform:scale(0.94)}
  .send-btn:disabled{opacity:0.35;cursor:default;transform:none;box-shadow:none}
  .send-btn svg{width:18px;height:18px}

  /* Footer */
  .footer{
    padding:9px 24px;border-top:1px solid rgba(255,255,255,0.04);
    display:flex;justify-content:space-between;align-items:center;flex-shrink:0;
  }
  .footer span{font-size:11px;color:rgba(167,139,250,0.2);font-weight:500}
  .clear-btn{font-size:11px;color:rgba(167,139,250,0.3);background:none;border:none;cursor:pointer;font-family:'Space Grotesk',sans-serif;padding:4px 10px;border-radius:8px;transition:all 0.15s}
  .clear-btn:hover{background:rgba(83,74,183,0.12);color:#AFA9EC}

  /* Confetti */
  .confetti-piece{position:fixed;width:8px;height:8px;border-radius:2px;pointer-events:none;z-index:9999;animation:confFall linear forwards}
  @keyframes confFall{0%{opacity:1;transform:translateY(-20px) rotate(0deg)}100%{opacity:0;transform:translateY(300px) rotate(720deg)}}
</style>
</head>
<body>
<div class="particle p1"></div>
<div class="particle p2"></div>
<div class="particle p3"></div>

<div class="app">
  <!-- HEADER -->
  <div class="header">
    <div class="logo">&#127891;</div>
    <div class="header-text">
      <h1>Study Buddy AI &#x2728;</h1>
      <p>Tanishq Gupta &middot; S.B. Jain Institute of Technology, Nagpur &middot; Code Sangram 2026</p>
    </div>
    <div class="status-badge"><div class="sdot"></div>AI online</div>
  </div>

  <!-- API KEY -->
  <div class="api-band" id="apiBand">
    <label>&#128273; API key</label>
    <input type="password" id="apiKey" placeholder="sk-ant-api03-..." />
    <button class="connect-btn" onclick="connectKey()">connect &#x26A1;</button>
    <div class="api-note">get free key at console.anthropic.com &mdash; stored only in session, never shared</div>
  </div>

  <!-- SUBJECTS -->
  <div class="subjects" id="subjects"></div>

  <!-- MESSAGES -->
  <div class="messages" id="messages">
    <div class="welcome" id="welcome">
      <div class="welcome-icon">&#127775;</div>
      <h2>heyyy bestie, what are we studying? &#x1F4DA;</h2>
      <p>no cap, i got the answers fr fr &mdash; pick a subject below or just type. i'm like your smartest friend who actually does the homework lmao</p>
      <div class="chips" id="chips"></div>
    </div>
  </div>

  <!-- INPUT -->
  <div class="input-area">
    <textarea id="inp" placeholder="ask me anything, no cap... &#x2728;" rows="1"></textarea>
    <button class="send-btn" id="sendBtn" disabled>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </div>

  <!-- FOOTER -->
  <div class="footer">
    <span>&#9889; Code Sangram Online Hackathon 2026 &mdash; AI Domain</span>
    <button class="clear-btn" onclick="clearChat()">clear chat</button>
  </div>
</div>

<script>
const SUBS={
  "&#127775; general":["how to study effectively?","create a study schedule for me","what are the best note-taking techniques?","how to overcome exam anxiety?"],
  "&#128290; maths":["explain quadratic equations with examples","how does integration work in calculus?","what are matrices and determinants?","explain probability and statistics"],
  "&#9889; physics":["explain newton's three laws simply","how does electromagnetism work?","what is quantum mechanics?","explain laws of thermodynamics"],
  "&#129514; chemistry":["how do ionic and covalent bonds work?","explain organic chemistry basics","what is stoichiometry?","explain periodic table trends"],
  "&#128187; CS":["explain data structures and algorithms","what is object-oriented programming?","how does recursion work?","explain Big O time complexity"],
  "&#127807; biology":["how does DNA replication work?","explain photosynthesis step by step","what is mitosis vs meiosis?","explain the immune system"],
  "&#128221; english":["help me write a strong essay introduction","explain types of sentences","how to analyze a poem?","tips for improving writing skills"]
};

let subKey=Object.keys(SUBS)[0],hist=[],loading=false,apiKey="";

function connectKey(){
  const v=document.getElementById("apiKey").value.trim();
  if(!v.startsWith("sk-ant-")){alert("enter a valid Anthropic API key (starts with sk-ant-)");return}
  apiKey=v;
  const band=document.getElementById("apiBand");
  band.style.background="rgba(29,158,117,0.06)";
  band.style.borderBottomColor="rgba(29,158,117,0.2)";
  band.innerHTML='<span style="font-size:13px;color:#5DCAA5;font-weight:600;">&#9989; connected! start chatting bestie &#x1F680;</span>';
  document.getElementById("sendBtn").disabled=false;
  document.getElementById("inp").focus();
}

function renderSubs(){
  document.getElementById("subjects").innerHTML=Object.keys(SUBS).map(s=>
    `<button class="subpill${s===subKey?' on':''}" onclick="pickSub(${JSON.stringify(s)})">${s}</button>`
  ).join("")
}
function renderChips(){
  const c=document.getElementById("chips");if(!c)return;
  c.innerHTML=SUBS[subKey].map(q=>`<button class="chip" onclick="send(${JSON.stringify(q)})">${q}</button>`).join("")
}
function pickSub(s){subKey=s;renderSubs();renderChips()}

function confetti(){
  const colors=["#AFA9EC","#ED93B1","#5DCAA5","#FAC775","#85B7EB"];
  for(let i=0;i<24;i++){
    setTimeout(()=>{
      const el=document.createElement("div");
      el.className="confetti-piece";
      el.style.cssText=`left:${Math.random()*100}%;top:${window.innerHeight*0.7}px;background:${colors[i%colors.length]};animation-duration:${0.8+Math.random()*0.6}s;animation-delay:${Math.random()*0.3}s;transform:rotate(${Math.random()*360}deg)`;
      document.body.appendChild(el);
      setTimeout(()=>el.remove(),1500);
    },i*18);
  }
}

function addBubble(role,text){
  const w=document.getElementById("welcome");if(w)w.remove();
  hist.push({role:role==="user"?"user":"assistant",content:text});
  const d=document.createElement("div");d.className="msg "+(role==="user"?"user":"bot");
  if(role!=="user"){const l=document.createElement("div");l.className="bot-label";l.textContent="STUDY BUDDY \u2022 AI";d.appendChild(l)}
  const b=document.createElement("div");b.className="bubble";b.textContent=text;d.appendChild(b);
  const m=document.getElementById("messages");m.appendChild(d);m.scrollTop=m.scrollHeight;
}
function showTyping(){
  const d=document.createElement("div");d.id="typing";d.className="msg bot";
  const l=document.createElement("div");l.className="bot-label";l.textContent="STUDY BUDDY \u2022 AI";
  const b=document.createElement("div");b.className="bubble typing-dots";
  b.innerHTML='<div class="td"></div><div class="td"></div><div class="td"></div>';
  d.appendChild(l);d.appendChild(b);
  const m=document.getElementById("messages");m.appendChild(d);m.scrollTop=m.scrollHeight;
}
function hideTyping(){const t=document.getElementById("typing");if(t)t.remove()}

async function send(text){
  text=(text||document.getElementById("inp").value).trim();
  if(!text||loading)return;
  if(!apiKey){alert("connect your API key first bestie!");return}
  document.getElementById("inp").value="";
  document.getElementById("inp").style.height="auto";
  loading=true;document.getElementById("sendBtn").disabled=true;
  addBubble("user",text);showTyping();
  const sys=`You are Study Buddy AI — an expert, friendly AI Student Assistant Chatbot for Code Sangram Online Hackathon 2026, built by Tanishq Gupta, S.B. Jain Institute of Technology, Nagpur.

Current subject focus: ${subKey}

Be the student's smartest, most helpful friend. Explain concepts clearly with examples, use step-by-step breakdowns, be encouraging. Keep answers focused (2-4 paragraphs). Offer to go deeper at the end.`;
  const msgs=hist.filter(m=>m.role==="user"||m.role==="assistant").map(m=>({role:m.role,content:m.content}));
  try{
    const r=await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",
      headers:{"Content-Type":"application/json","x-api-key":apiKey,"anthropic-version":"2023-06-01","anthropic-dangerous-direct-browser-access":"true"},
      body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1024,system:sys,messages:msgs})
    });
    const data=await r.json();hideTyping();
    if(data.error){addBubble("assistant","error: "+data.error.message);return}
    const reply=data.content?.map(c=>c.text||"").join("")||"couldn't respond rn, try again!";
    addBubble("assistant",reply);confetti();
  }catch(e){hideTyping();addBubble("assistant","oof connection error! check API key + internet and try again fr")}
  loading=false;document.getElementById("sendBtn").disabled=false;document.getElementById("inp").focus();
}

function clearChat(){
  hist=[];
  const m=document.getElementById("messages");m.innerHTML="";
  const w=document.createElement("div");w.id="welcome";w.className="welcome";
  w.innerHTML='<div class="welcome-icon">&#127775;</div><h2>heyyy bestie, what are we studying? &#x1F4DA;</h2><p>no cap, i got the answers fr fr — pick a subject below or just type. i\'m like your smartest friend who actually does the homework lmao</p><div class="chips" id="chips"></div>';
  m.appendChild(w);renderChips();
}

document.getElementById("sendBtn").addEventListener("click",()=>send(document.getElementById("inp").value));
document.getElementById("inp").addEventListener("keydown",e=>{if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();send(document.getElementById("inp").value)}});
document.getElementById("inp").addEventListener("input",function(){this.style.height="auto";this.style.height=Math.min(this.scrollHeight,120)+"px"});

renderSubs();renderChips();
</script>
</body>
</html>
